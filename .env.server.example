# Core app URL and CORS
APP_BASE_URL=https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Admin endpoint protection (used by reconciliation and protected API routes)
ADMIN_API_KEY=replace-with-strong-random-value

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Clerk webhook verification
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Cal webhook verification
CAL_WEBHOOK_SECRET=your-cal-webhook-secret

# Resend (optional but recommended for pay-at-counter confirmation)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Gateway Resort <bookings@your-domain.com>