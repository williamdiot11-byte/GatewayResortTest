{
  "name": "gateway-resort",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Client",
    "Server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=Client",
    "build": "npm run build --workspace=Client",
    "dev:server": "npm run dev --workspace=Server",
    "dev:all": "concurrently \"npm run dev --workspace=Client\" \"npm run dev --workspace=Server\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
